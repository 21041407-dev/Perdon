<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Perdón Creativo</title>
  <style>
    body {
      background: linear-gradient(to right, #ff9a9e, #fad0c4);
      font-family: 'Comic Sans MS', cursive, sans-serif;
      text-align: center;
      padding-top: 60px;
      overflow: hidden;
    }
    h1 {
      color: #ff0066;
      font-size: 65px;
      animation: heartbeat 1.5s infinite;
    }
    p {
      font-size: 26px;
      color: #333;
      margin-top: 20px;
    }
    .btn {
      display: inline-block;
      margin: 20px;
      padding: 15px 35px;
      background-color: #ff0066;
      color: white;
      text-decoration: none;
      border-radius: 30px;
      font-size: 22px;
      transition: transform 0.3s;
      cursor: pointer;
    }
    .btn:hover:enabled {
      transform: rotate(5deg) scale(1.2);
      background-color: #ff3399;
    }
    .btn:disabled {
      background-color: #999;
      cursor: not-allowed;
    }
    #mensaje {
      margin-top: 30px;
      font-size: 30px;
      color: #0066cc;
      font-weight: bold;
      animation: fadeIn 2s ease-in-out;
    }
    @keyframes heartbeat {
      0% { transform: scale(1); }
      25% { transform: scale(1.2); }
      50% { transform: scale(1); }
      75% { transform: scale(1.2); }
      100% { transform: scale(1); }
    }
    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }
    /* Corazones flotando */
    .corazon {
      position: absolute;
      font-size: 30px;
      animation: flotar 6s infinite;
      color: #ff3366;
    }
    @keyframes flotar {
      0% { transform: translateY(0); opacity: 1; }
      100% { transform: translateY(-600px); opacity: 0; }
    }
  </style>
</head>
<body>
  <h1>💖 Perdóname, Amor 💖</h1>
  <p>Me equivoqué y lo sé...<br>
     Pero mi corazón late solo por ti.<br>
     Quiero volver a empezar contigo. 🌹</p>
  
  <button class="btn" onclick="aceptar()">Sí, volvamos a ser felices</button>
  <button class="btn" id="noBtn" disabled>No perdonar</button>
  
  <div id="mensaje"></div>

  <!-- Corazones flotando -->
  <div class="corazon" style="left:10%; animation-delay:0s;">❤️</div>
  <div class="corazon" style="left:30%; animation-delay:2s;">💖</div>
  <div class="corazon" style="left:50%; animation-delay:4s;">💕</div>
  <div class="corazon" style="left:70%; animation-delay:1s;">💞</div>
  <div class="corazon" style="left:90%; animation-delay:3s;">💘</div>

  <script>
    function aceptar() {
      document.getElementById("mensaje").innerHTML = "✨ Gracias por perdonarme... ¡Prometo hacerte feliz cada día! ✨";
      document.getElementById("noBtn").disabled = false;
    }
    document.getElementById("noBtn").onclick = function() {
      alert("😅 ¡Demasiado tarde, ya dijiste que sí! 💘");
    }
  </script>
</body>
</html>
